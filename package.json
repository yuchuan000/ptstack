{
  "name": "ptstack",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint:spellcheck": "cspell lint \"(packages|apps)/**/*.{js,ts,mjs,cjs,json,css,less,scss,vue,html,md}\"",
    "commit": "git-cz",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "tsc:admin": "pnpm -F @ptstack/web-admin exec vue-tsc --noEmit",
    "tsc:client": "pnpm -F @ptstack/web-client exec nuxi typecheck",
    "tsc:server": "pnpm -F @ptstack/api-server exec tsc --noEmit",
    "tsc:components": "pnpm -F @ptstack/components exec tsc --noEmit",
    "tsc:utils": "pnpm -F @ptstack/utils exec tsc --noEmit",
    "tsc:types": "pnpm -F @ptstack/types exec tsc --noEmit",
    "dev": "turbo dev"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@types/node": "catalog:",
    "commitizen": "^4.3.1",
    "cspell": "^10.0.0",
    "cz-git": "^1.13.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "turbo": "^2.9.14",
    "typescript": "catalog:"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "devEngines": {
    "node": "^22.19.0"
  },
  "packageManager": "pnpm@11.1.1",
  "dependencies": {
    "dayjs": "^1.11.20",
    "zod": "^4.4.3"
  }
}
