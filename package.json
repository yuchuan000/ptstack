    "@commitlint/config-conventional": "^21.0.1",
    "@types/node": "^25.8.0",
    "commitizen": "^4.3.1",
    "cspell": "^10.0.0",
    "cz-git": "^1.13.1",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "typescript": "^6.0.3"
