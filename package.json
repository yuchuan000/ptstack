{
  "name": "ptstack",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint:spellcheck": "cspell lint \"(packages|apps)/**/*.{js,ts,mjs,cjs,json,css,less,scss,vue,html,md}\"",
    "commit": "git-cz",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "tsc:admin": "pnpm -F @ptstack/web-admin exec vue-tsc --noEmit",
    "tsc:client": "pnpm -F @ptstack/web-client exec nuxi typecheck",
    "tsc:server": "pnpm -F @ptstack/api-server exec tsc --noEmit",
    "tsc:components": "pnpm -F @ptstack/components exec tsc --noEmit",
    "tsc:utils": "pnpm -F @ptstack/utils exec tsc --noEmit",
    "dev": "concurrently -n server,admin,client -c yellow,green,blue \"pnpm -F @ptstack/api-server dev\" \"pnpm -F @ptstack/web-admin dev\" \"pnpm -F @ptstack/web-client dev\"",
    "dev:server": "pnpm -F @ptstack/api-server dev",
    "dev:admin": "pnpm -F @ptstack/web-admin dev",
    "dev:client": "pnpm -F @ptstack/web-client dev",
    "dev:frontend": "concurrently -n admin,client -c green,blue \"pnpm -F @ptstack/web-admin dev\" \"pnpm -F @ptstack/web-client dev\""
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@types/node": "catalog:",
    "commitizen": "^4.3.1",
    "concurrently": "^9.2.1",
    "cspell": "^10.0.0",
    "cz-git": "^1.13.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "typescript": "catalog:"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "devEngines": {
    "node": "^22.19.0",
    "packageManager": {
      "name": "pnpm",
      "version": "^11.1.1",
      "onFail": "download"
    }
  }
}
